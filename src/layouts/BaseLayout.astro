---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dashcam.io — Your phone is your dashcam',
  description = "Turn any smartphone into an AI dashcam. Loop recording, crash detection, on-device AI, Android Auto. Mount it. Drive. You're protected.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#00C7BE" />
    <meta name="color-scheme" content="light" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" href="/icon-round.png" />
    <link rel="apple-touch-icon" href="/icon-round.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/icon.png" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/icon.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
