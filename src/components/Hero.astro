---
---

<section class="hero">
  <div class="orbs" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
  </div>

  <div class="wrap hero-inner">
    <div class="hero-copy">
      <span class="eyebrow">
        <span class="dot"></span>
        Android — coming soon
      </span>
      <h1>Your phone is your dashcam.</h1>
      <p class="lede">
        Mount it. Drive. You're protected.
        Dashcam.io turns any Android phone into a full AI dashcam —
        loop recording, crash detection, on-device object tracking,
        and AI trip summaries that run entirely on the device.
        No hardware to buy. No subscription to record.
      </p>
      <div class="cta-row">
        <a href="#download" class="btn btn-primary">
          Get the app
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#features" class="btn btn-ghost">See what it does</a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="icon-glow"></div>
      <div class="icon-stage">
        <img src="/icon.png" alt="" class="hero-icon" width="432" height="432" />
      </div>

      <!-- Floating "live" chips that hint at the product's UI, without
           faking an entire phone mockup. Positioned around the icon so
           the cat-camera character remains the focal point. -->
      <div class="chip chip-rec">
        <span class="rec-dot"></span>
        REC · 02:14
      </div>
      <div class="chip chip-speed">
        <span class="speed-num">58</span>
        <span class="speed-unit">km/h</span>
      </div>
      <div class="chip chip-detect">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="3"/>
          <path d="M3 9h18M9 3v18"/>
        </svg>
        4 cars · 2 pedestrians
      </div>
      <div class="chip chip-crash">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2 4 6v6c0 5 3.5 9.4 8 10 4.5-.6 8-5 8-10V6l-8-4z"/>
          <path d="m9 12 2 2 4-4"/>
        </svg>
        Safe trip
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 72px 0 112px;
    position: relative;
    overflow: hidden;
  }

  /* Ambient background color blobs — echo the icon's gradient palette */
  .orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.5;
  }

  .orb-1 {
    top: -120px;
    right: 10%;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(0, 199, 190, 0.35) 0%, transparent 70%);
  }

  .orb-2 {
    bottom: -80px;
    left: 5%;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(90, 200, 250, 0.25) 0%, transparent 70%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 56px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    max-width: 560px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(0, 199, 190, 0.12);
    color: var(--color-primary-dark);
    border-radius: 100px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 24px;
  }

  .dot {
    width: 6px;
    height: 6px;
    background: var(--color-primary);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero h1 {
    margin-bottom: 20px;
    background: linear-gradient(180deg, #000 0%, #2a2a2e 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .lede {
    font-size: 1.13rem;
    color: var(--color-text-muted);
    margin-bottom: 36px;
    line-height: 1.6;
  }

  .cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* === Hero visual — big cat-camera icon floating in a teal nebula === */

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 520px;
  }

  .icon-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 560px;
    height: 560px;
    background:
      radial-gradient(circle at 50% 45%, rgba(0, 199, 190, 0.28) 0%, transparent 55%),
      radial-gradient(circle at 50% 55%, rgba(90, 200, 250, 0.18) 0%, transparent 60%);
    z-index: 0;
    pointer-events: none;
    animation: breathe 5s ease-in-out infinite;
  }

  @keyframes breathe {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
    50% { transform: translate(-50%, -50%) scale(1.06); opacity: 0.85; }
  }

  .icon-stage {
    position: relative;
    z-index: 1;
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .hero-icon {
    display: block;
    width: 320px;
    height: 320px;
    filter:
      drop-shadow(0 24px 56px rgba(0, 199, 190, 0.25))
      drop-shadow(0 8px 20px rgba(10, 20, 80, 0.18));
  }

  /* Floating UI chips — hint at the product's functionality without
     drawing a full phone mockup that would compete with the icon. */
  .chip {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    box-shadow: 0 8px 24px rgba(10, 20, 80, 0.1);
    z-index: 2;
    white-space: nowrap;
  }

  .chip svg {
    width: 14px;
    height: 14px;
    color: var(--color-primary-dark);
  }

  .chip-rec {
    top: 12%;
    left: -4%;
    color: var(--color-primary-dark);
    animation: float-a 4s ease-in-out infinite;
  }

  .rec-dot {
    width: 8px;
    height: 8px;
    background: var(--color-red);
    border-radius: 50%;
    animation: pulse 1.1s ease-in-out infinite;
  }

  .chip-speed {
    top: 4%;
    right: -2%;
    padding: 10px 18px;
    animation: float-b 5s ease-in-out infinite;
  }

  .speed-num {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }

  .speed-unit {
    font-size: 11px;
    color: var(--color-text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .chip-detect {
    bottom: 18%;
    left: -8%;
    animation: float-c 4.5s ease-in-out infinite;
  }

  .chip-crash {
    bottom: 10%;
    right: -4%;
    color: var(--color-primary-dark);
    animation: float-d 5.5s ease-in-out infinite;
  }

  @keyframes float-a { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
  @keyframes float-b { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  @keyframes float-c { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }
  @keyframes float-d { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-9px); } }

  /* Tablet & mobile */
  @media (max-width: 960px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 56px;
      text-align: center;
    }
    .hero-copy { max-width: 100%; }
    .cta-row { justify-content: center; }
    .eyebrow { margin-left: auto; margin-right: auto; }
    .hero-visual { min-height: 460px; }
    .icon-glow { width: 460px; height: 460px; }
    .hero-icon { width: 280px; height: 280px; }
    .chip-rec { left: 0; }
    .chip-speed { right: 0; }
    .chip-detect { left: 0; }
    .chip-crash { right: 0; }
  }

  @media (max-width: 640px) {
    .hero { padding: 48px 0 72px; }
    .hero-visual { min-height: 380px; }
    .icon-glow { width: 380px; height: 380px; }
    .hero-icon { width: 220px; height: 220px; }
    .chip { font-size: 12px; padding: 8px 14px; }
    .chip-rec { top: 6%; }
    .chip-speed { top: 0; }
    .chip-detect { bottom: 12%; }
    .chip-crash { bottom: 6%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .icon-glow,
    .icon-stage,
    .chip-rec,
    .chip-speed,
    .chip-detect,
    .chip-crash,
    .dot,
    .rec-dot {
      animation: none;
    }
  }
</style>
