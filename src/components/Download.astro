<section class="download section" id="download">
  <div class="wrap inner">
    <h2>Coming soon to Google Play.</h2>
    <p>
      Android 8.0 and up. iOS in the works.
      Want to know when we go live? Follow the project.
    </p>
    <div class="cta-row">
      <a
        href="https://github.com/spyamine/dashcam-io"
        class="btn btn-primary"
        target="_blank"
        rel="noopener noreferrer"
      >
        Follow on GitHub
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.7 1.6.2 2.9.1 3.2.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.3v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3z"/>
        </svg>
      </a>
      <a href="mailto:hello@byteflowers.com" class="btn btn-ghost">Get updates</a>
    </div>
  </div>
</section>

<style>
  .download {
    background: linear-gradient(180deg, var(--color-bg) 0%, #e8f5f4 100%);
    padding-bottom: 120px;
  }

  .inner {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  h2 {
    margin-bottom: 14px;
  }

  p {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-bottom: 32px;
  }

  .cta-row {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
