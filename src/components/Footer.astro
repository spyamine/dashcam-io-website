---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer-inner">
    <div class="brand">
      <img src="/icon-round.png" alt="" width="32" height="32" />
      <span>Dashcam.io</span>
    </div>
    <p class="tagline">
      A <a href="https://byteflowers.com" target="_blank" rel="noopener noreferrer">ByteFlowers</a> project.
      © {year}.
    </p>
    <p class="mini">
      Your phone is your dashcam. Mount it. Drive. You're protected.
    </p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-card);
    border-top: 1px solid var(--color-border);
    padding: 48px 0;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-align: center;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 16px;
    color: var(--color-text);
  }

  /* icon-round.png already has a circular mask baked in */

  .tagline {
    color: var(--color-text-muted);
    font-size: 14px;
  }

  .mini {
    color: var(--color-text-muted);
    font-size: 13px;
    margin-top: 4px;
    max-width: 400px;
  }
</style>
